# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Chat Backend (OpenAI-compatible API — works with OpenAI, Anthropic via proxy, OpenRouter, local LLMs, etc.)
# If not set, Scout AI chat will show a "Configure AI in Settings" message.
# All other features (NYC data, scoring, pipeline, outreach) work without AI.
VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
VITE_AI_API_KEY=your-ai-api-key
VITE_AI_MODEL=gpt-4o

# Anthropic (optional — if using Anthropic directly via their SDK/proxy)
# VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# Apollo.io (contact enrichment)
VITE_APOLLO_API_KEY=your-apollo-api-key

# Prospeo (email verification fallback)
VITE_PROSPEO_API_KEY=your-prospeo-api-key

# Scout + HubSpot Integrations
# Server-side values should be configured in Render environment variables.
SCOUT_API_URL=https://your-scout-api.example.com
SCOUT_API_KEY=your-scout-api-key
SCOUT_WORKSPACE_ID=your-scout-workspace-id
HUBSPOT_API_KEY=your-hubspot-private-app-token
HUBSPOT_CREATE_DEALS=false
HUBSPOT_PIPELINE_ID=default
HUBSPOT_DEAL_STAGE_ID=your-hubspot-deal-stage-id

# Legacy/browser-only HubSpot CRM fallback
VITE_HUBSPOT_API_KEY=your-hubspot-api-key

# Google Maps (optional, for embeds)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# RealtyMX (optional, for Sentinel live rental inventory / DOM / unit mix)
VITE_REALTYMX_API_KEY=your-realtymx-api-key

# Merlin Gmail OAuth client ID used by setup:merlin and Supabase Edge Functions.
MERLIN_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Merlin Gmail OAuth client secret used only as a server-side secret.
MERLIN_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Merlin Gmail refresh token generated by npm run setup:merlin.
MERLIN_GMAIL_REFRESH_TOKEN=your-merlin-refresh-token

# Dedicated mailbox owned by the Daily Lead Hunt bot.
MERLIN_EMAIL_ADDRESS=merlin@camelot.nyc

# Optional comma-separated Gmail label IDs for Merlin reply classification.
MERLIN_LABEL_IDS=lead_reply,meeting_request,do_not_contact
